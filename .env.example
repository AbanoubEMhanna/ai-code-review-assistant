# Local AI host — Ollama default is http://localhost:11434
#               — LM Studio default is http://localhost:1234
#               — Not used when AI_PROVIDER=anthropic
AI_HOST=http://localhost:11434

# Model to use for reviews
# Ollama/LM Studio default: qwen3:latest
# Anthropic default: claude-sonnet-4-6
AI_MODEL=qwen3:latest

# Provider: ollama | lmstudio | anthropic
AI_PROVIDER=ollama

# Anthropic API key — required when AI_PROVIDER=anthropic
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Tip: instead of env vars, you can create .ai-reviewrc.json in the project root:
#   ai-review config init   — scaffold a .ai-reviewrc.json with current defaults
#   ai-review config show   — print the active config and where it comes from
# Priority (highest first): CLI flags > env vars > .ai-reviewrc.json > built-in defaults
